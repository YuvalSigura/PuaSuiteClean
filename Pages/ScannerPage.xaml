<Page x:Class="PuaSuiteClean.Pages.ScannerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Scanner">
    <Grid Background="#1e1e1e">
        <StackPanel Margin="20">
            <TextBlock Text="Scanner Module"
                       Foreground="White"
                       FontSize="22"
                       Margin="0 0 0 20"/>

            <Button Content="Start Scan"
                    Height="35"
                    Width="120"
                    Click="StartScan_Click"/>

            <TextBox x:Name="OutputBox"
                     Margin="0 20 0 0"
                     Height="250"
                     Background="Black"
                     Foreground="Lime"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>
        </StackPanel>
    </Grid>
</Page>

<UserControl x:Class="PuaSuiteClean.Pages.LoaderWizard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">

    <Border Style="{StaticResource PuaPanel}">
        <StackPanel>

            <TextBlock Text="Loader Execution Wizard"
                       Style="{StaticResource PuaHeader}"/>

            <Button Content="Run Loader"
                    Style="{StaticResource PuaButton}"
                    Click="BtnRun_Click"/>

            <TextBox x:Name="TxtOutput"
                     Height="220"
                     Background="Black"
                     Foreground="#99DDFF"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>
    </Border>

</UserControl>

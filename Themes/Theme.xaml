<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- COLORS -->
    <Color x:Key="PrimaryBordeaux">#7A1128</Color>
    <Color x:Key="DarkBackground">#1A1A1A</Color>
    <Color x:Key="DarkPanel">#202020</Color>
    <Color x:Key="BorderBordeaux">#991533</Color>
    <Color x:Key="TextSoft">#DDDDDD</Color>

    <!-- BRUSHES -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryBordeaux}"/>
    <SolidColorBrush x:Key="ForegroundSoft" Color="{StaticResource TextSoft}"/>
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource DarkPanel}"/>
    <SolidColorBrush x:Key="BorderBrushBordeaux" Color="{StaticResource BorderBordeaux}"/>

    <!-- BUTTON STYLE -->
    <Style x:Key="PuaButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="0 6 0 6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="root" Property="Background" Value="#A6143C"/>
                            <Setter TargetName="root" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#A6143C"
                                                      BlurRadius="20"
                                                      ShadowDepth="0"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="root" Property="Background" Value="#5D0C20"/>
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PANEL STYLE -->
    <Style x:Key="PuaPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
    </Style>

    <!-- TEXT STYLE -->
    <Style x:Key="PuaHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundSoft}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0 0 0 10"/>
    </Style>

</ResourceDictionary>
